# Database (Neon)
DATABASE_URL=postgres://user:password@your-neon-host/neondb

# NextAuth
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your_auth_secret

# OAuth Providers (example: GitHub)
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# Market data providers (optional but recommended)
TIINGO_API_KEY=your_tiingo_api_key
POLYGON_API_KEY=your_polygon_api_key

# Optional: Analytics (if you want to add them later)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Optional: Sentry (for error tracking)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Optional: OpenAI (for AI insights)
# OPENAI_API_KEY=sk-...
